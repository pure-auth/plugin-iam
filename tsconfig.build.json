{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "module": "Preserve",
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "pure-auth": ["../core/dist/index.d.ts"],
      "@pure-auth/plugin-organization": ["../plugin-organization/dist/index.d.ts"]
    },
    "rootDir": "./src",
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
